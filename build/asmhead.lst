     1 00000000                                 ; haribote-os boot asm
     2 00000000                                 ; TAB=4
     3 00000000                                 
     4 00000000                                 [INSTRSET "i486p"]
     5 00000000                                 
     6  = 00004144                              VBEMODE	EQU		0x4144			; 1024 x  768 x 8bit 彩色 105
     7 00000000                                 ; 显示模式
     8 00000000                                 ;	0x100 :  640 x  400 x 8bit 彩色
     9 00000000                                 ;	0x101 :  640 x  480 x 8bit 彩色
    10 00000000                                 ;	0x103 :  800 x  600 x 8bit 彩色
    11 00000000                                 ;	0x105 : 1024 x  768 x 8bit 彩色
    12 00000000                                 ;	0x107 : 1280 x 1024 x 8bit 彩色
    13 00000000                                 
    14  = 00280000                              BOTPAK	EQU		0x00280000		; 加载bootpack
    15  = 00100000                              DSKCAC	EQU		0x00100000		; 磁盘缓存的位置
    16  = 00008000                              DSKCAC0	EQU		0x00008000		; 磁盘缓存的位置（实模式）
    17 00000000                                 
    18 00000000                                 ; BOOT_INFO 相关
    19  = 00000FF0                              CYLS	EQU		0x0ff0			; 引导扇区设置
    20  = 00000FF1                              LEDS	EQU		0x0ff1
    21  = 00000FF2                              VMODE	EQU		0x0ff2			; 关于颜色的信息
    22  = 00000FF4                              SCRNX	EQU		0x0ff4			; 分辨率X
    23  = 00000FF6                              SCRNY	EQU		0x0ff6			; 分辨率Y
    24  = 00000FF8                              VRAM	EQU		0x0ff8			; 图像缓冲区的起始地址
    25 00000000                                 
    26                                          		ORG		0xc200			;  这个的程序要被装载的内存地址
    27 0000C200                                 
    28 0000C200                                 ; 确认VBE是否存在
    29 0000C200                                 
    30 0000C200 B8 9000                         		MOV		AX,0x9000
    31 0000C203 8E C0                           		MOV		ES,AX
    32 0000C205 BF 0000                         		MOV		DI,0
    33 0000C208 B8 4F00                         		MOV		AX,0x4f00
    34 0000C20B CD 10                           		INT		0x10
    35 0000C20D 3D 004F                         		CMP		AX,0x004f
    36 0000C210 75 61                           		JNE		scrn320
    37 0000C212                                 
    38 0000C212                                 ; 检查VBE的版本
    39 0000C212                                 
    40 0000C212 26 8B 45 04                     		MOV		AX,[ES:DI+4]
    41 0000C216 3D 0200                         		CMP		AX,0x0200
    42 0000C219 72 58                           		JB		scrn320			; if (AX < 0x0200) goto scrn320
    43 0000C21B                                 
    44 0000C21B                                 ;
    45 0000C21B                                 
    46 0000C21B                                 ; --- 1. 取得画面模式信息 (0x4f01) ---
    47 0000C21B B9 4144                         		MOV		CX,VBEMODE
    48 0000C21E B8 4F01                         		MOV		AX,0x4f01
    49 0000C221 CD 10                           		INT		0x10
    50 0000C223 3D 004F                         		CMP		AX,0x004f
    51 0000C226 75 4B                           		JNE		scrn320
    52 0000C228                                 
    53 0000C228                                 ; --- 2. 【核心修改】在切换模式前，立刻把信息搬走 ---
    54 0000C228 26 8B 45 12                     		MOV		AX,[ES:DI+0x12]
    55 0000C22C A3 0FF4                         		MOV		[SCRNX],AX			; 存宽
    56 0000C22F 26 8B 45 14                     		MOV		AX,[ES:DI+0x14]
    57 0000C233 A3 0FF6                         		MOV		[SCRNY],AX			; 存高
    58 0000C236                                 		
    59 0000C236 26 8A 45 19                     		MOV		AL,[ES:DI+0x19]
    60 0000C23A A2 0FF3                         		MOV		[0x0ff3],AL			; 存位数 (BPP)
    61 0000C23D                                 		
    62 0000C23D 26 8B 45 10                     		MOV		AX,[ES:DI+0x10]
    63 0000C241 A3 0FFC                         		MOV		[0x0ffc],AX			; 存关键的 Pitch
    64 0000C244                                 
    65 0000C244 66 26 8B 45 28                  		MOV		EAX,[ES:DI+0x28]
    66 0000C249 66 A3 0FF8                      		MOV		[VRAM],EAX			; 存最关键的 VRAM 地址
    67 0000C24D                                 
    68 0000C24D                                 
    69 0000C24D                                 ;	画面设置
    70 0000C24D                                 
    71 0000C24D BB 8144                         		MOV		BX,VBEMODE+0x4000
    72 0000C250 B8 4F02                         		MOV		AX,0x4f02
    73 0000C253 CD 10                           		INT		0x10
    74 0000C255 C6 06 0FF2 02                   		MOV		BYTE [VMODE],2	; 屏幕的模式（参考C语言的引用）
    75 0000C25A 26 8B 45 12                     		MOV		AX,[ES:DI+0x12]
    76 0000C25E A3 0FF4                         		MOV		[SCRNX],AX
    77 0000C261 26 8B 45 14                     		MOV		AX,[ES:DI+0x14]
    78 0000C265 A3 0FF6                         		MOV		[SCRNY],AX
    79 0000C268 66 26 8B 45 28                  		MOV		EAX,[ES:DI+0x28] ;VRAM的地址
    80 0000C26D 66 A3 0FF8                      		MOV		[VRAM],EAX
    81 0000C271 EB 20                           		JMP		keystatus
    82 0000C273                                 
    83 0000C273                                 scrn320:
    84 0000C273 B0 13                           		MOV		AL,0x13						; VGA图、320x200x8bit彩色
    85 0000C275 B4 00                           		MOV		AH,0x00
    86 0000C277 CD 10                           		INT		0x10
    87 0000C279 C6 06 0FF2 08                   		MOV		BYTE [VMODE],8		; 记下画面模式（参考C语言）
    88 0000C27E C7 06 0FF4 0140                 		MOV		WORD [SCRNX],320
    89 0000C284 C7 06 0FF6 00C8                 		MOV		WORD [SCRNY],200
    90 0000C28A 66 C7 06 0FF8 000A0000          		MOV		DWORD [VRAM],0x000a0000
    91 0000C293                                 
    92 0000C293                                 ;	通过 BIOS 获取指示灯状态
    93 0000C293                                 
    94 0000C293                                 keystatus:
    95 0000C293 B4 02                           		MOV		AH,0x02
    96 0000C295 CD 16                           		INT		0x16 			; keyboard BIOS
    97 0000C297 A2 0FF1                         		MOV		[LEDS],AL
    98 0000C29A                                 
    99 0000C29A                                 ;	PIC关闭一切中断
   100 0000C29A                                 ;	根据AT兼容机的规格，如果要初始化PIC，
   101 0000C29A                                 ;	必须在CLI之前进行，否则有时会挂起。
   102 0000C29A                                 ;	随后进行PIC的初始化。
   103 0000C29A                                 
   104 0000C29A B0 FF                           		MOV		AL,0xff
   105 0000C29C E6 21                           		OUT		0x21,AL
   106 0000C29E 90                              		NOP						; 如果连续执行OUT指令，有些机种会无法正常运行
   107 0000C29F E6 A1                           		OUT		0xa1,AL
   108 0000C2A1                                 
   109 0000C2A1 FA                              		CLI						; 禁止CPU级别的中断
   110 0000C2A2                                 
   111 0000C2A2                                 ;	为了让CPU能够访问1MB以上的内存空间，设定A20GATE
   112 0000C2A2                                 
   113 0000C2A2 E8 00B5                         		CALL	waitkbdout
   114 0000C2A5 B0 D1                           		MOV		AL,0xd1
   115 0000C2A7 E6 64                           		OUT		0x64,AL
   116 0000C2A9 E8 00AE                         		CALL	waitkbdout
   117 0000C2AC B0 DF                           		MOV		AL,0xdf			; enable A20
   118 0000C2AE E6 60                           		OUT		0x60,AL
   119 0000C2B0 E8 00A7                         		CALL	waitkbdout
   120 0000C2B3                                 
   121 0000C2B3                                 ;	切换到保护模式
   122 0000C2B3                                 
   123 0000C2B3                                 [INSTRSET "i486p"]				; 说明使用486指令
   124 0000C2B3                                 
   125 0000C2B3 0F 01 16 C39A                   		LGDT	[GDTR0]			; 设置临时GDT
   126 0000C2B8 0F 20 C0                        		MOV		EAX,CR0
   127 0000C2BB 66 25 7FFFFFFF                  		AND		EAX,0x7fffffff	; 设bit31为0（禁用分页）
   128 0000C2C1 66 83 C8 01                     		OR		EAX,0x00000001	; bit0到1转换（保护模式过渡）
   129 0000C2C5 0F 22 C0                        		MOV		CR0,EAX
   130 0000C2C8 EB 00                           		JMP		pipelineflush
   131 0000C2CA                                 pipelineflush:
   132 0000C2CA B8 0008                         		MOV		AX,1*8			;  可读写的段 32bit
   133 0000C2CD 8E D8                           		MOV		DS,AX
   134 0000C2CF 8E C0                           		MOV		ES,AX
   135 0000C2D1 8E E0                           		MOV		FS,AX
   136 0000C2D3 8E E8                           		MOV		GS,AX
   137 0000C2D5 8E D0                           		MOV		SS,AX
   138 0000C2D7                                 
   139 0000C2D7                                 ; bootpack传递
   140 0000C2D7                                 
   141 0000C2D7 66 BE 0000C3A0                  		MOV		ESI,bootpack	; 转送源
   142 0000C2DD 66 BF 00280000                  		MOV		EDI,BOTPAK		; 转送目标
   143 0000C2E3 66 B9 00020000                  		MOV		ECX,512*1024/4
   144 0000C2E9 E8 0075                         		CALL	memcpy
   145 0000C2EC                                 
   146 0000C2EC                                 ; 磁盘数据最终转送到它本来的位置去
   147 0000C2EC                                 ; 首先从启动扇区开始
   148 0000C2EC                                 
   149 0000C2EC 66 BE 00007C00                  		MOV		ESI,0x7c00		; 转送源
   150 0000C2F2 66 BF 00100000                  		MOV		EDI,DSKCAC		; 转送目标
   151 0000C2F8 66 B9 00000080                  		MOV		ECX,512/4
   152 0000C2FE E8 0060                         		CALL	memcpy
   153 0000C301                                 
   154 0000C301                                 ; 剩余的全部
   155 0000C301                                 
   156 0000C301 66 BE 00008200                  		MOV		ESI,DSKCAC0+512	; 转送源
   157 0000C307 66 BF 00100200                  		MOV		EDI,DSKCAC+512	; 转送源目标
   158 0000C30D 66 B9 00000000                  		MOV		ECX,0
   159 0000C313 8A 0E 0FF0                      		MOV		CL,BYTE [CYLS]
   160 0000C317 66 69 C9 00001200               		IMUL	ECX,512*18*2/4	; 从柱面数变换为字节数/4
   161 0000C31E 66 81 E9 00000080               		SUB		ECX,512/4		; 减去 IPL 偏移量
   162 0000C325 E8 0039                         		CALL	memcpy
   163 0000C328                                 
   164 0000C328                                 ; 必须由asmhead来完成的工作，至此全部完毕
   165 0000C328                                 ; 以后就交由bootpack来完成
   166 0000C328                                 
   167 0000C328                                 ; bootpack启动
   168 0000C328                                 
   169 0000C328 66 BB 00280000                  		MOV		EBX,BOTPAK
   170 0000C32E 67 66 8B 4B 10                  		MOV		ECX,[EBX+16]
   171 0000C333 66 83 C1 03                     		ADD		ECX,3			; ECX += 3;
   172 0000C337 66 C1 E9 02                     		SHR		ECX,2			; ECX /= 4;
   173 0000C33B 74 10                           		JZ		skip			; 没有要转送的东西时
   174 0000C33D 67 66 8B 73 14                  		MOV		ESI,[EBX+20]	; 转送源
   175 0000C342 66 01 DE                        		ADD		ESI,EBX
   176 0000C345 67 66 8B 7B 0C                  		MOV		EDI,[EBX+12]	; 转送目标
   177 0000C34A E8 0014                         		CALL	memcpy
   178 0000C34D                                 skip:
   179 0000C34D 67 66 8B 63 0C                  		MOV		ESP,[EBX+12]	; 堆栈的初始化
   180 0000C352 66 EA 0000001B 0010             		JMP		DWORD 2*8:0x0000001b
   181 0000C35A                                 
   182 0000C35A                                 waitkbdout:
   183 0000C35A E4 64                           		IN		 AL,0x64
   184 0000C35C 24 02                           		AND		 AL,0x02
   185 0000C35E 75 FA                           		JNZ		waitkbdout	; AND的结果如果不是0，就跳到waitkbdout
   186 0000C360 C3                              		RET
   187 0000C361                                 
   188 0000C361                                 memcpy:
   189 0000C361 67 66 8B 06                     		MOV		EAX,[ESI]
   190 0000C365 66 83 C6 04                     		ADD		ESI,4
   191 0000C369 67 66 89 07                     		MOV		[EDI],EAX
   192 0000C36D 66 83 C7 04                     		ADD		EDI,4
   193 0000C371 66 83 E9 01                     		SUB		ECX,1
   194 0000C375 75 EA                           		JNZ		memcpy			; 减法运算的结果如果不是0，就跳转到memcpy
   195 0000C377 C3                              		RET
   196 0000C378                                 ; memcpy地址前缀大小
   197 0000C378                                 
   198 0000C378 00 00 00 00 00 00 00 00         		ALIGNB	16
   199 0000C380                                 GDT0:
   200 0000C380 00 00 00 00 00 00 00 00         		RESB	8				; 初始值
   201 0000C388 FFFF 0000 9200 00CF             		DW		0xffff,0x0000,0x9200,0x00cf	; 可以读写的段（segment）32bit
   202 0000C390 FFFF 0000 9A28 0047             		DW		0xffff,0x0000,0x9a28,0x0047	; 可执行的文件的32bit寄存器（bootpack用）
   203 0000C398                                 
   204 0000C398 0000                            		DW		0
   205 0000C39A                                 GDTR0:
   206 0000C39A 0017                            		DW		8*3-1
   207 0000C39C 0000C380                        		DD		GDT0
   208 0000C3A0                                 
   209 0000C3A0                                 		ALIGNB	16
   210 0000C3A0                                 bootpack:
