   244 00000139                                 _memtest_sub:	; unsigned int memtest_sub(unsigned int start, unsigned int end)
   245 00000139 57                              		PUSH	EDI						; （由于还要使用EBX, ESI, EDI）
   246 0000013A 56                              		PUSH	ESI
   247 0000013B 53                              		PUSH	EBX
   248 0000013C BE AA55AA55                     		MOV		ESI,0xaa55aa55			; pat0 = 0xaa55aa55;
   249 00000141 BF 55AA55AA                     		MOV		EDI,0x55aa55aa			; pat1 = 0x55aa55aa;
   250 00000146 8B 44 24 10                     		MOV		EAX,[ESP+12+4]			; i = start;
   251 0000014A                                 mts_loop:
   252 0000014A 89 C3                           		MOV		EBX,EAX
   253 0000014C 81 C3 00000FFC                  		ADD		EBX,0xffc				; p = i + 0xffc;
   254 00000152 8B 13                           		MOV		EDX,[EBX]				; old = *p;
   255 00000154 89 33                           		MOV		[EBX],ESI				; *p = pat0;
   256 00000156 83 33 FF                        		XOR		DWORD [EBX],0xffffffff	; *p ^= 0xffffffff;
   257 00000159 3B 3B                           		CMP		EDI,[EBX]				; if (*p != pat1) goto fin;
   258 0000015B 75 18                           		JNE		mts_fin
   259 0000015D 83 33 FF                        		XOR		DWORD [EBX],0xffffffff	; *p ^= 0xffffffff;
   260 00000160 3B 33                           		CMP		ESI,[EBX]				; if (*p != pat0) goto fin;
   261 00000162 75 11                           		JNE		mts_fin
   262 00000164 89 13                           		MOV		[EBX],EDX				; *p = old;
   263 00000166 05 00001000                     		ADD		EAX,0x1000				; i += 0x1000;
   264 0000016B 3B 44 24 14                     		CMP		EAX,[ESP+12+8]			; if (i <= end) goto mts_loop;
   265 0000016F 76 D9                           		JBE		mts_loop
   266 00000171 5B                              		POP		EBX
   267 00000172 5E                              		POP		ESI
   268 00000173 5F                              		POP		EDI
   269 00000174 C3                              		RET
   270 00000175                                 mts_fin:
   271 00000175 89 13                           		MOV		[EBX],EDX				; *p = old;
   272 00000177 5B                              		POP		EBX
   273 00000178 5E                              		POP		ESI
   274 00000179 5F                              		POP		EDI
   275 0000017A C3                              		RET
   276 0000017B                                 
   277 0000017B                                 _farjmp:		; void farjmp(int eip, int cs);
   278 0000017B FF 6C 24 04                     		JMP    FAR [ESP+4]    ; eip, cs
   279 0000017F C3                              		RET