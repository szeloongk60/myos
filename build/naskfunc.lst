   195 000000F4                                 _memtest_sub:	; unsigned int memtest_sub(unsigned int start, unsigned int end)
   196 000000F4 57                              		PUSH	EDI						; （由于还要使用EBX, ESI, EDI）
   197 000000F5 56                              		PUSH	ESI
   198 000000F6 53                              		PUSH	EBX
   199 000000F7 BE AA55AA55                     		MOV		ESI,0xaa55aa55			; pat0 = 0xaa55aa55;
   200 000000FC BF 55AA55AA                     		MOV		EDI,0x55aa55aa			; pat1 = 0x55aa55aa;
   201 00000101 8B 44 24 10                     		MOV		EAX,[ESP+12+4]			; i = start;
   202 00000105                                 mts_loop:
   203 00000105 89 C3                           		MOV		EBX,EAX
   204 00000107 81 C3 00000FFC                  		ADD		EBX,0xffc				; p = i + 0xffc;
   205 0000010D 8B 13                           		MOV		EDX,[EBX]				; old = *p;
   206 0000010F 89 33                           		MOV		[EBX],ESI				; *p = pat0;
   207 00000111 83 33 FF                        		XOR		DWORD [EBX],0xffffffff	; *p ^= 0xffffffff;
   208 00000114 3B 3B                           		CMP		EDI,[EBX]				; if (*p != pat1) goto fin;
   209 00000116 75 18                           		JNE		mts_fin
   210 00000118 83 33 FF                        		XOR		DWORD [EBX],0xffffffff	; *p ^= 0xffffffff;
   211 0000011B 3B 33                           		CMP		ESI,[EBX]				; if (*p != pat0) goto fin;
   212 0000011D 75 11                           		JNE		mts_fin
   213 0000011F 89 13                           		MOV		[EBX],EDX				; *p = old;
   214 00000121 05 00001000                     		ADD		EAX,0x1000				; i += 0x1000;
   215 00000126 3B 44 24 14                     		CMP		EAX,[ESP+12+8]			; if (i <= end) goto mts_loop;
   216 0000012A 76 D9                           		JBE		mts_loop
   217 0000012C 5B                              		POP		EBX
   218 0000012D 5E                              		POP		ESI
   219 0000012E 5F                              		POP		EDI
   220 0000012F C3                              		RET
   221 00000130                                 mts_fin:
   222 00000130 89 13                           		MOV		[EBX],EDX				; *p = old;
   223 00000132 5B                              		POP		EBX
   224 00000133 5E                              		POP		ESI
   225 00000134 5F                              		POP		EDI
   226 00000135 C3                              		RET
   227 00000136                                 
   228 00000136                                 _farjmp:		; void farjmp(int eip, int cs);
   229 00000136 FF 6C 24 04                     		JMP    FAR [ESP+4]    ; eip, cs
   230 0000013A C3                              		RET